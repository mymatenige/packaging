/srv/mythtv/logs/*.log {
        weekly
        rotate 8
        missingok
        ifempty
        nocreate
        nocompress
        sharedscripts
        olddir /srv/mythtv/logs/old
        su mythtv mythtv
        lastaction
                killall -HUP mythlogserver
                find /srv/mythtv/logs/old -type f -mtime +30 -delete
        endscript
} 
