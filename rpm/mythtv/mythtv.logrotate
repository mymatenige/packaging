/var/log/mythtv/*.log {
        weekly
        rotate 8
        missingok
        ifempty
        nocreate
        nocompress
        sharedscripts
        olddir /var/log/mythtv/old
        su mythtv mythtv
        lastaction
                killall -HUP mythlogserver
                find /var/log/mythtv/old -type f -mtime +30 -delete
        endscript
} 
